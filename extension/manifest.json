{
  "manifest_version": 3,
  "name": "Hermes Browser Bridge",
  "version": "0.4.0",
  "description": "Menghubungkan AI Agent ke sesi browser aktif Anda dengan aman",
  "minimum_chrome_version": "116",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage",
    "sidePanel",
    "debugger",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Buka Hermes Bridge Panel"
  }
}
